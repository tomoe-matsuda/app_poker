# 公開サイト URL（OGP・sitemap・canonical）。Vercel 本番ドメインを設定
NEXT_PUBLIC_SITE_URL=https://storypoint-poker.vercel.app

# GA4（いずれか）。未設定ならタグは出ません
# NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX
# NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID=G-XXXXXXXXXX

# --- Notion API（サーバーのみ参照。クライアントに含めない） ---
# Notion インテグレーションの Internal Integration Secret
NOTION_API_KEY=

# 連携するデータベースの ID（Notion URL のデータベース部分）
# @notionhq/client 最新版は DB に紐づく data source を自動で query します
NOTION_DATABASE_ID=

# タイトル列の名前（既定: Name）
# NOTION_TITLE_PROPERTY=Name

# 編集 UI で更新するプロパティ（Notion 上の表示名と完全一致）
# NOTION_EDITABLE_NUMBER_PROP=ストーリーポイント
# NOTION_EDITABLE_DATE_PROP=更新日

# 任意: /notion と /api/notion を Basic 認証で保護
# NOTION_PAGE_BASIC_AUTH_USER=
# NOTION_PAGE_BASIC_AUTH_PASSWORD=

# --- Stripe（プレミアム・カード決済）---
# STRIPE_SECRET_KEY=sk_live_...
# STRIPE_PRICE_ID=price_...（サブスクリプション用 Price ID）

# --- Notion OAuth（プレミアムのルーム連携。Notion の Public インテグレーション）---
# NOTION_OAUTH_CLIENT_ID=
# NOTION_OAUTH_CLIENT_SECRET=
# NOTION_OAUTH_REDIRECT_URI=https://あなたのドメイン/api/notion/oauth/callback

# 未課金時は Notion モーダルでアップグレードのみ表示
# NEXT_PUBLIC_PREMIUM_REQUIRED_FOR_NOTION=true
# ルーム内で Notion OAuth 連携 UI を出す（近日公開モードのときは false のまま）
# NEXT_PUBLIC_PREMIUM_NOTION_LIVE=true
