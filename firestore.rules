rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function isValidFibonacciPoint(n) {
      return n in [1, 2, 3, 5, 8, 13, 21];
    }

    // ルームコレクション
    match /rooms/{roomId} {
      allow read: if true;

      allow create: if request.resource.data.maxParticipants >= 1
                    && request.resource.data.maxParticipants <= 20
                    && request.resource.data.participants is list
                    && request.resource.data.participants.size() == 0;

      // 参加人数上限は変更させない。参加者リストは上限以内
      allow update: if request.resource.data.maxParticipants == resource.data.maxParticipants
                    && request.resource.data.participants is list
                    && request.resource.data.participants.size() <= request.resource.data.maxParticipants;

      allow delete: if false;
    }

    // 投票履歴コレクション
    match /voteHistory/{historyId} {
      allow read: if true;

      allow create: if request.resource.data.roomId is string
                    && request.resource.data.taskName is string
                    && isValidFibonacciPoint(request.resource.data.finalPoint);

      allow update: if false;

      // やり直しでホストが削除する想定。本番では認証・Cloud Functions 経由への限定を推奨
      allow delete: if true;
    }
  }
}
